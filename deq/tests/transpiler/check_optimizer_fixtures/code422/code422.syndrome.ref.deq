@PTYPE(1)
CODE Code422 [[4,2,2]] {
    LOGICAL X0*X1 Z0*Z2
    LOGICAL X0*X2 Z0*Z1
    STABILIZER X0*X1*X2*X3  # generator S0, destabilizer DS0=Z0*Z1*Z2
    STABILIZER Z0*Z1*Z2*Z3  # generator S1, destabilizer DS1=X3
}

@GTYPE(1)
@CHECKS("manual", verify=0)
GADGET PrepareXX {
    RX 0 1 2 3
    MPP Z0*Z1*Z2*Z3
    OUTPUT Code422 0 1 2 3
    CHECK rec[-2]
    CHECK rec[-1] rec[-3]

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 2
    #   weight distribution: { 1:1, 2:1 }
    # errors: 0
}

@GTYPE(2)
@CHECKS("manual", verify=0)
GADGET PrepareZZ {
    R 0 1 2 3
    MPP X0*X1*X2*X3
    OUTPUT Code422 0 1 2 3
    CHECK rec[-2] rec[-3]
    CHECK rec[-1]

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 2
    #   weight distribution: { 1:1, 2:1 }
    # errors: 0
}

@GTYPE(3)
@CHECKS("manual", verify=0)
GADGET CX {
    INPUT Code422 0 1 2 3
    INPUT Code422 4 5 6 7
    CX 0 4 1 5 2 6 3 7
    OUTPUT Code422 0 1 2 3
    OUTPUT Code422 4 5 6 7
    CHECK rec[-4] rec[-6] rec[-8]
    CHECK rec[-3] rec[-7]
    CHECK rec[-2] rec[-6]
    CHECK rec[-1] rec[-5] rec[-7]

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 4
    #   weight distribution: { 2:2, 3:2 }
    # errors: 0
}

@GTYPE(4)
@CHECKS("manual", verify=0)
GADGET Permute {
    INPUT Code422 0 1 2 3
    OUTPUT Code422 1 0 3 2
    CHECK rec[-2] rec[-4]
    CHECK rec[-1] rec[-3]

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 2
    #   weight distribution: { 2:2 }
    # errors: 0
}

@GTYPE(5)
@CHECKS("manual", verify=0)
GADGET MeasureZZ {
    INPUT Code422 0 1 2 3
    M 0 1 2 3
    READOUT rec[-4] rec[-2]  # flipped by: LX0
    READOUT rec[-4] rec[-3]  # flipped by: LX1

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 0
    # errors: 0
}

@GTYPE(6)
@CHECKS("manual", verify=0)
GADGET MeasureXX {
    INPUT Code422 0 1 2 3
    MX 0 1 2 3
    READOUT rec[-4] rec[-3]  # flipped by: LZ0
    READOUT rec[-4] rec[-2]  # flipped by: LZ1


    # errors: 0
}

@GTYPE(3)
@CHECKS("manual", verify=0)
GADGET MeasureZ {
    INPUT SurfaceCode 0 1 2 3 4 5 6 7 8
    MZ 0 1 2 3 4 5 6 7 8
    READOUT rec[-9] rec[-6] rec[-3]  # flipped by: LX0
    CHECK rec[-7] rec[-8] rec[-17]
    CHECK rec[-2] rec[-3] rec[-10]

    # --- statistics ---
    # finished checks: 2

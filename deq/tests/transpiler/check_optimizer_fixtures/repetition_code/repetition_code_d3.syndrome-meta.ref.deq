    CX 0 1 2 3 4 5
    CX 2 1 4 3
    M 1 3 5
    CHECK rec[-9] rec[-12]
    CHECK rec[-8] rec[-11]
    CHECK rec[-8] rec[-9] rec[-10]
    CHECK rec[-3] rec[-9]
    CHECK rec[-2] rec[-8]
    CHECK rec[-1] rec[-7]
    CHECK rec[-3] rec[-6]
    CHECK rec[-2] rec[-5]
    CHECK rec[-1] rec[-4]
    OUTPUT RepetitionCode 0 2 4
    CHECK rec[-3] rec[-12]
    CHECK rec[-2] rec[-11]
    CHECK rec[-1] rec[-11] rec[-12]

    # --- statistics ---
    # finished checks: 9

@PTYPE(1)
CODE RepetitionCode [[3,1,3]] {
    LOGICAL X0*X1*X2 Z0
    STABILIZER Z0*Z1  # generator S0, destabilizer DS0=X1*X2
    STABILIZER Z1*Z2  # generator S1, destabilizer DS1=X2
    STABILIZER Z2*Z0
}

@GTYPE(1)
@CHECKS("manual", verify=0)
GADGET PrepareZ {
    R 0 1 2
    OUTPUT RepetitionCode 0 1 2
    CHECK rec[-3]
    CHECK rec[-2]
    CHECK rec[-1]

    # --- statistics ---
    # finished checks: 0
    # unfinished checks: 3
    #   weight distribution: { 1:3 }
    # errors: 0
}

@GTYPE(2)
@CHECKS("manual", verify=0)
GADGET MeasureZ {
    INPUT RepetitionCode 0 1 2
    M 0 1 2
    READOUT rec[-3]  # flipped by: LX0
    CHECK rec[-2] rec[-3] rec[-6]
    CHECK rec[-1] rec[-2] rec[-5]
    CHECK rec[-1] rec[-3] rec[-4]

    # --- statistics ---
    # finished checks: 3
    #   weight distribution: { 3:3 }
    # unfinished checks: 0
    # errors: 0
}


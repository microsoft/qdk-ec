

CODE SurfaceCode [[9,1,3]] {
    LOGICAL X0*X1*X2 Z0*Z3*Z6
    STABILIZER Z1*Z2 X0*X3 Z0*Z1*Z3*Z4 X1*X2*X4*X5 X3*X4*X6*X7 Z4*Z5*Z7*Z8 X5*X8 Z6*Z7
}

GADGET AutomorphismIdentity {
    INPUT SurfaceCode 0 1 2 3 4 5 6 7 8
    I 0 1 2 3 4 5 6 7 8  # so that error can be injected
    DEPOLARIZE1(0.001) 0 1 2 3 4 5 6 7 8
    OUTPUT SurfaceCode 8 7 6 5 4 3 2 1 0
}

GADGET PrepareZ {
    RZ 0 1 2 3 4 5 6 7 8
    X_ERROR(0.001) 0 1 2 3 4 5 6 7 8
    
    RZ 9 11 14 16
    X_ERROR(0.001) 9 11 14 16
    RX 10 12 13 15
    Z_ERROR(0.001) 10 12 13 15

    # layer 1: both interacts with top-left
    CNOT 0 11 4 14 6 16 
    DEPOLARIZE2(0.001) 0 11 4 14 6 16
    CNOT 12 1 13 3 15 5 
    DEPOLARIZE2(0.001) 12 1 13 3 15 5
    # layer 2: Z interacts with top-right, X interacts with bottom-left
    CNOT 1 11 5 14 7 16 
    DEPOLARIZE2(0.001) 1 11 5 14 7 16
    CNOT 12 4 13 6 15 8 
    DEPOLARIZE2(0.001) 12 4 13 6 15 8
    # layer 3: Z interacts with bottom-left, X interacts with top-right
    CNOT 1 9 3 11 7 14 
    DEPOLARIZE2(0.001) 1 9 3 11 7 14
    CNOT 10 0 12 2 13 4 
    DEPOLARIZE2(0.001) 10 0 12 2 13 4
    # layer 4: both interacts with bottom-right
    CNOT 2 9 4 11 8 14 
    DEPOLARIZE2(0.001) 2 9 4 11 8 14
    CNOT 10 3 12 5 13 7 
    DEPOLARIZE2(0.001) 10 3 12 5 13 7

    MZ(0.001) 9 11 14 16
    MX(0.001) 10 12 13 15

    OUTPUT SurfaceCode 0 1 2 3 4 5 6 7 8
}

GADGET PrepareX {
    RX 0 1 2 3 4 5 6 7 8
    Z_ERROR(0.001) 0 1 2 3 4 5 6 7 8
    
    RZ 9 11 14 16
    X_ERROR(0.001) 9 11 14 16
    RX 10 12 13 15
    Z_ERROR(0.001) 10 12 13 15

    # layer 1: both interacts with top-left
    CNOT 0 11 4 14 6 16 
    DEPOLARIZE2(0.001) 0 11 4 14 6 16
    CNOT 12 1 13 3 15 5 
    DEPOLARIZE2(0.001) 12 1 13 3 15 5
    # layer 2: Z interacts with top-right, X interacts with bottom-left
    CNOT 1 11 5 14 7 16 
    DEPOLARIZE2(0.001) 1 11 5 14 7 16
    CNOT 12 4 13 6 15 8 
    DEPOLARIZE2(0.001) 12 4 13 6 15 8
    # layer 3: Z interacts with bottom-left, X interacts with top-right
    CNOT 1 9 3 11 7 14 
    DEPOLARIZE2(0.001) 1 9 3 11 7 14
    CNOT 10 0 12 2 13 4 
    DEPOLARIZE2(0.001) 10 0 12 2 13 4
    # layer 4: both interacts with bottom-right
    CNOT 2 9 4 11 8 14 
    DEPOLARIZE2(0.001) 2 9 4 11 8 14
    CNOT 10 3 12 5 13 7 
    DEPOLARIZE2(0.001) 10 3 12 5 13 7

    MZ(0.001) 9 11 14 16
    MX(0.001) 10 12 13 15

    OUTPUT SurfaceCode 0 1 2 3 4 5 6 7 8
}

GADGET MeasureZ {
    INPUT SurfaceCode 0 1 2 3 4 5 6 7 8
    MZ(0.001) 0 1 2 3 4 5 6 7 8
    READOUT rec[-9] rec[-6] rec[-3]
}

GADGET MeasureX {
    INPUT SurfaceCode 0 1 2 3 4 5 6 7 8
    MX(0.001) 0 1 2 3 4 5 6 7 8
    READOUT rec[-9] rec[-8] rec[-7]
}

GADGET Syndrome {
    INPUT SurfaceCode 0 1 2 3 4 5 6 7 8
    
    RZ 9 11 14 16
    X_ERROR(0.001) 9 11 14 16
    RX 10 12 13 15
    Z_ERROR(0.001) 10 12 13 15

    # layer 1: both interacts with top-left
    CNOT 0 11 4 14 6 16 
    DEPOLARIZE2(0.001) 0 11 4 14 6 16
    CNOT 12 1 13 3 15 5 
    DEPOLARIZE2(0.001) 12 1 13 3 15 5
    # layer 2: Z interacts with top-right, X interacts with bottom-left
    CNOT 1 11 5 14 7 16 
    DEPOLARIZE2(0.001) 1 11 5 14 7 16
    CNOT 12 4 13 6 15 8 
    DEPOLARIZE2(0.001) 12 4 13 6 15 8
    # layer 3: Z interacts with bottom-left, X interacts with top-right
    CNOT 1 9 3 11 7 14 
    DEPOLARIZE2(0.001) 1 9 3 11 7 14
    CNOT 10 0 12 2 13 4 
    DEPOLARIZE2(0.001) 10 0 12 2 13 4
    # layer 4: both interacts with bottom-right
    CNOT 2 9 4 11 8 14 
    DEPOLARIZE2(0.001) 2 9 4 11 8 14
    CNOT 10 3 12 5 13 7 
    DEPOLARIZE2(0.001) 10 3 12 5 13 7

    MZ(0.001) 9 11 14 16
    MX(0.001) 10 12 13 15

    OUTPUT SurfaceCode 0 1 2 3 4 5 6 7 8
}

COMPOSE FTSyndrome {
    INPUT SurfaceCode 0
    REPEAT 3 {
        Syndrome 0
    }
    OUTPUT SurfaceCode 0
}

COMPOSE FTPrepareZ {
    PrepareZ 0
    REPEAT 2 {
        Syndrome 0
    }
    OUTPUT SurfaceCode 0
}

COMPOSE FTPrepareX {
    PrepareX 0
    REPEAT 2 {
        Syndrome 0
    }
    OUTPUT SurfaceCode 0
}

GADGET NOP {
    INPUT SurfaceCode 0 1 2 3 4 5 6 7 8
    OUTPUT SurfaceCode 0 1 2 3 4 5 6 7 8
}

GADGET TransversalCNOT {
    INPUT SurfaceCode 0 1 2 3 4 5 6 7 8
    INPUT SurfaceCode 9 10 11 12 13 14 15 16 17

    CX 0 9 1 10 2 11 3 12 4 13 5 14 6 15 7 16 8 17
    DEPOLARIZE2(0.001) 0 9 1 10 2 11 3 12 4 13 5 14 6 15 7 16 8 17

    OUTPUT SurfaceCode 0 1 2 3 4 5 6 7 8
    OUTPUT SurfaceCode 9 10 11 12 13 14 15 16 17
}

PROGRAM MemoryExperiment {
    PrepareZ 0
    FTSyndrome 0
    MeasureZ 0
    ASSERT_EQ rec[-1] 0
}

PROGRAM HiddenShift {
    PrepareX 0
    PrepareZ 1
    TransversalCNOT 0 1
    AutomorphismIdentity 1
    TransversalCNOT 0 1
    MeasureX 0
    MeasureZ 1
    ASSERT_EQ rec[-1] 0
    ASSERT_EQ rec[-2] 0
}


